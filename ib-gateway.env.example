# IB Gateway Docker configuration
# Copy to ib-gateway.env and fill in your credentials.
# ib-gateway.env is .gitignored — credentials stay on EC2 only.

# ── IBKR Credentials ─────────────────────────────────────────────────────────
TWS_USERID=
TWS_PASSWORD=

# ── Trading Mode ─────────────────────────────────────────────────────────────
TRADING_MODE=paper

# ── API Settings ─────────────────────────────────────────────────────────────
READ_ONLY_API=no

# ── VNC (for weekly 2FA approval) ────────────────────────────────────────────
# Connect via: ssh -NL 5900:localhost:5900 ec2-user@<IP>
# Then open vnc://localhost:5900
VNC_SERVER_PASSWORD=changeme

# ── Auto-Restart (keeps gateway running without daily 2FA) ───────────────────
AUTO_RESTART_TIME=11:59 PM
TWOFA_TIMEOUT_ACTION=restart
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
EXISTING_SESSION_DETECTED_ACTION=primary

# ── Timezone ─────────────────────────────────────────────────────────────────
TIME_ZONE=America/New_York
